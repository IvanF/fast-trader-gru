# Bybit API credentials (required for OMS live execution)
# Modes (pick ONE):
#   Demo:    BYBIT_DEMO=true, keys from bybit.com while in Demo Trading mode
#   Testnet: BYBIT_TESTNET=true, keys from testnet.bybit.com
#   Mainnet: both false, keys from bybit.com (real funds)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_DEMO=false
BYBIT_TESTNET=false
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear

# Screener filters
SCREEN_INTERVAL=1h
MIN_TURNOVER_24H=50000000
MAX_FUNDING_RATE=0.001
MIN_FUNDING_RATE=-0.001
BLACKLIST_SYMBOLS=BSBUSDT

# ML Engine — PyTorch training runs on GPU (TRAIN_DEVICE=cuda)
CONFIDENCE_THRESHOLD=0.65
KILL_CONFIDENCE_THRESHOLD=0.35
ENTRY_ABORT_THRESHOLD=0.50
CORRELATION_THRESHOLD=0.75
VOL_MULTIPLIER_CAP=2.0
ENTRY_MAKER_TICKS=1
MEMORY_DECAY_DAYS=14
TRAIN_DEVICE=cuda

# OMS — position sizing (USD margin × leverage → notional → qty)
ACCOUNT_DEPOSIT_USD=100
TRADE_MARGIN_USD=10
LEVERAGE=5
TIME_STOP_SECONDS=3600
ORDER_FILL_TIMEOUT_SEC=3600
ENTRY_REPRICE_THRESHOLD_PCT=0.002
EXIT_REPRICE_THRESHOLD_PCT=0.002
STALE_ENTRY_MOVE_AWAY_PCT=0.015
STALE_ENTRY_MIN_AGE_SEC=5
PENDING_VOL_REPRICE_DELTA=0.5
PARTIAL_CLOSE_PCT=0.45
MIN_SL_PCT=0.003
MIN_TP_PCT=0.004
MAX_TP_PCT=0.008
FEE_BREAKEVEN_PCT=0.002
TP_BUDGET_PCT=0.45
EXIT_GRID_MIN_REDEPLOY_SEC=30
DECAY_OBI_THRESHOLD=0.30
ADVERSE_CONFIRM_TICKS=3
MAX_SIGNAL_CONFIDENCE=0.98
TELEMETRY_INTERVAL_SEC=5
# Softmax movement probability (optional weight override: JSON 3x5 matrix and len-3 bias)
# MOVEMENT_PROB_WEIGHTS=[[-1.4,-1.2,0.15,-0.5,-0.9],[0,0,-0.6,0,0],[1.4,1.2,0.15,0.5,0.9]]
# MOVEMENT_PROB_BIAS=[0,0.35,0]
MOVEMENT_PROB_FUNDING_PRIOR_SCALE=50
DEFAULT_ORDER_QTY=0.01

# Redis lifecycle events (OMS → ML alpha-decay tracking)
POSITIONS_CHANNEL=execution:positions
PENDING_ORDERS_CHANNEL=execution:pending_orders

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Host ports (FTG block — avoids infra-redis :6379, sen-* :80xx, etc.)
FTG_REDIS_PORT=16379
FTG_INFLUX_PORT=18086
FTG_PROMETHEUS_PORT=19090
FTG_GRAFANA_PORT=13000

# ONNX Runtime (Docker cpuset — disable invalid CPU affinity)
ORT_DISABLE_CPU_AFFINITY=1
ORT_INTRA_OP_THREADS=4
ORT_INTER_OP_THREADS=2

# InfluxDB 2.x (Historical Data Lake)
INFLUX_USER=admin
INFLUX_PASSWORD=adminpassword
INFLUX_ORG=fasttrader
INFLUX_TOKEN=ftg-super-secret-token-change-me
INFLUX_BUCKET_RAW=market_raw
INFLUX_BUCKET_FEATURES=market_features

# Model hot-swap
MODEL_RELOAD_CHANNEL=models:reload
MODEL_WATCH_INTERVAL_SEC=10

# Rolling retrain feedback loop
RETRAIN_INTERVAL_HOURS=2
RETRAIN_TRADE_THRESHOLD=100
RETRAIN_LOOKBACK_HOURS=6
RETRAIN_EPOCHS=8
RETRAIN_TIMEOUT_SEC=3600
TRAIN_NICE_LEVEL=15
LOSS_PENALTY_WEIGHT=2.5
RETRAIN_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT
